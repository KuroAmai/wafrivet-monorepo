# API Gateway (all apps) — base URL includes /api/v1
API_URL=https://wafrivet-api-gateway-wdvfp4toqa-ew.a.run.app/api/v1
NEXT_PUBLIC_API_URL=https://wafrivet-api-gateway-wdvfp4toqa-ew.a.run.app/api/v1
VITE_API_URL=https://wafrivet-api-gateway-wdvfp4toqa-ew.a.run.app/api/v1

# Core herd fallback
NEXT_PUBLIC_CORE_URL=https://wafrivet-core-wdvfp4toqa-ew.a.run.app
VITE_CORE_URL=https://wafrivet-core-wdvfp4toqa-ew.a.run.app

# Field Vet (herd farmer PIN — if used)
NEXT_PUBLIC_FIELD_VET_URL=https://wafrivet-field-vet-wdvfp4toqa-ew.a.run.app
VITE_FIELD_VET_URL=https://wafrivet-field-vet-wdvfp4toqa-ew.a.run.app

# App URLs (redirects)
NEXT_PUBLIC_APP_URL=https://app.wafrivet.com
NEXT_PUBLIC_SHOP_URL=https://shop.wafrivet.com
NEXT_PUBLIC_HERD_URL=https://herd.wafrivet.com

# Shared session cookie across *.wafrivet.com (required in production for app + shop + herd)
AUTH_COOKIE_DOMAIN=.wafrivet.com
NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.wafrivet.com

# Dev only — allows mock-token cookie
NEXT_PUBLIC_ENABLE_MOCK_AUTH=false
VITE_ENABLE_MOCK_AUTH=false

# Dev only — show "continue without code" on /verify (requires AUTH_SKIP_EMAIL_OTP on API)
NEXT_PUBLIC_AUTH_SKIP_EMAIL_OTP=false
